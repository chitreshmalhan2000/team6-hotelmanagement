@model List<HotelManagement.MVC.ViewModels.ReviewViewModel>
@{
    ViewData["Title"] = "Reviews";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Reviews</h2>
    <a class="btn btn-success" asp-action="Create">Add Review</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Reservation ID</th>
            <th>Rating</th>
            <th>Comment</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ReviewId</td>
            <td>@item.ReservationId</td>
            <td>@item.Rating</td>
            <td>@item.Comment</td>
            <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
        </tr>
    }
    </tbody>
</table>
