@model HotelManagement.MVC.ViewModels.CreateAmenityViewModel
@{
    ViewData["Title"] = "Create Amenity";
}

<h2>Create Amenity</h2>
<form asp-action="Create" method="post" class="w-75">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

<div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>
